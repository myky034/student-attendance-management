generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Grade {
  id          String   @id @default(cuid())
  name        String
  description String
  color       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     Class[]
}

model Class {
  id               String             @id @default(cuid())
  name             String
  gradeId          String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  is_special_class Boolean?
  AttendanceRecord AttendanceRecord[]
  grade            Grade              @relation(fields: [gradeId], references: [id])
  students         User[]
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  username          String             @unique
  password          String
  role              UserRole
  qrCode            String?
  classId           String?
  isActive          Boolean            @default(true)
  isDeleted         Boolean            @default(false)
  isLocked          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdAttendance AttendanceRecord[] @relation("CreatedByAttendance")
  studentAttendance AttendanceRecord[] @relation("StudentAttendance")
  class             Class?             @relation(fields: [classId], references: [id], onDelete: Restrict)
}

model AttendanceRecord {
  id               String           @id @default(cuid())
  date             DateTime         @db.Date
  status           AttendanceStatus
  timestamp        DateTime         @default(now())
  studentId        String
  createdById      String
  semedter_id      BigInt?
  academic_year_id BigInt?
  class_id         String?
  AcademicYear     AcademicYear?    @relation(fields: [academic_year_id], references: [id], onUpdate: NoAction)
  Class            Class?           @relation(fields: [class_id], references: [id], onUpdate: NoAction)
  createdBy        User             @relation("CreatedByAttendance", fields: [createdById], references: [id])
  Semester         Semester?        @relation(fields: [semedter_id], references: [id], onUpdate: NoAction)
  student          User             @relation("StudentAttendance", fields: [studentId], references: [id])
}

model AcademicYear {
  id               BigInt             @id @default(autoincrement())
  name             String?            @db.VarChar
  start_date       DateTime?          @db.Date
  end_date         DateTime?          @db.Date
  is_active        Boolean?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  update_at        DateTime?          @default(now()) @db.Timestamptz(6)
  AttendanceRecord AttendanceRecord[]
  Semester         Semester[]
}

model Semester {
  id               BigInt             @id @default(autoincrement())
  name             String             @db.VarChar
  code             String?            @db.VarChar
  start_date       DateTime?          @db.Date
  end_date         DateTime?          @db.Date
  sort_order       Decimal?           @db.Decimal
  is_active        Boolean?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  update_at        DateTime?          @default(now()) @db.Timestamptz(6)
  academic_year_id BigInt?
  AttendanceRecord AttendanceRecord[]
  AcademicYear     AcademicYear?      @relation(fields: [academic_year_id], references: [id], onUpdate: NoAction)
}

enum UserRole {
  admin
  student
  teacher
}

enum AttendanceStatus {
  present
  absent
  excused_absence
}
